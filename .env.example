# Backend (.env bu örnekten kopyalanır: backend/.env)
# ---------------------------------------------------
DJANGO_SECRET_KEY=change-me-to-random-50-chars
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (Neon connection string)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Redis (Upstash)
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# JWT
JWT_SIGNING_KEY=change-me-to-random
JWT_ACCESS_LIFETIME_MIN=15
JWT_REFRESH_LIFETIME_DAYS=30

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Ekim Craft <hello@ekimcraft.com>

# SMS (NetGSM)
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_MSGHEADER=EKIMCRAFT

# Ödeme (iyzico)
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Depolama (Cloudflare R2 — S3 API)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ekim-craft-media
R2_PUBLIC_URL=https://cdn.ekimcraft.com

# E-fatura (Logo İşbaşı)
LOGO_ISBASI_USERNAME=
LOGO_ISBASI_PASSWORD=
LOGO_ISBASI_COMPANY_ID=

# Kargo (API key'ler entegrasyon fazında)
ARAS_USERNAME=
ARAS_PASSWORD=
ARAS_CUSTOMER_CODE=

# Sentry (opsiyonel)
SENTRY_DSN=


# Frontend (frontend/.env.local)
# ---------------------------------------------------
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=change-me
# NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3000
